import sys

n = int(sys.stdin.readline())

square = [i*i for i in range(1,int(n**0.5)+1)]

if int(n**0.5)*2 ==n:
    print(1)
    exit()

for s in square:
    if int((n-s)**0.5)**2==n-s:
        print(2)
        exit()

for i in square:
    for j in square:
        if i+j>n:
            break
        if int((n - i - j)**0.5)**2 == n - i - j:
            print(3)
            exit()

print(4)